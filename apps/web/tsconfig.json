{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "plugins": [
      { "name": "next" }
    ],

    "baseUrl": "src",

    "paths": {
      "@/*": ["*"],
      "@app/*": ["app/*"],
      "@components/*": ["components/*"],
      "@ui/*": ["ui/*"],
      "@lib/*": ["lib/*"],
      "@hooks/*": ["hooks/*"],
      "@providers/*": ["src/app/providers/*"]
    },

    "noEmit": true,
    "incremental": true,
    "jsx": "preserve"
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}
