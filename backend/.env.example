# ---------------------------------------------------------------------------
# ABLE Backend — environment template
# Copy to `.env` and fill in real values. NEVER commit a populated `.env`.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# Comma-separated allowed origins, or "*" for any origin.
# NOTE: "*" is rejected at boot when NODE_ENV=production — set an explicit
# allowlist there, e.g. CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# Rate limiting (windows in milliseconds). The auth limiter is stricter and
# applies to login/register/verify/refresh; the global limiter applies app-wide.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Public base URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Persistence
# Matches the docker-compose Postgres service credentials for local dev.
DATABASE_URL=postgresql://able:able@localhost:5432/able
REDIS_URL=redis://localhost:6379

# JWT is signed with RS256. Provide base64-encoded PEM keys. Generate with:
#   node scripts/gen-jwt-keys.mjs
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=able-ai-platform

# Password hashing work factor (bcrypt). 10-15.
BCRYPT_ROUNDS=12

# Email (Resend). Without a key, a log transport is used in development.
RESEND_API_KEY=
EMAIL_FROM=ABLE <onboarding@resend.dev>

# OAuth providers (optional — routes mount only when configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# Defaults to ${APP_URL}/auth/callback
OAUTH_SUCCESS_REDIRECT=

# AI provider abstraction (used by later phases)
AI_PROVIDER=local
AI_MODEL=

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
