{
  "name": "able",
  "version": "1.0.0",
  "description": "ABLE: AI-powered creator economy platform",
  "private": true,
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "dev": "pnpm --filter=./apps/* --filter=./packages/* --parallel run dev",
    "build": "pnpm --filter=./packages/* run build && pnpm --filter=./apps/* run build",
    "test": "pnpm --filter=./apps/* --filter=./packages/* run test",
    "test:unit": "pnpm --filter=./apps/* --filter=./packages/* run test:unit",
    "test:integration": "pnpm --filter=./apps/* run test:integration",
    "lint": "pnpm --filter=./apps/* --filter=./packages/* run lint",
    "type-check": "pnpm --filter=./apps/* --filter=./packages/* run type-check",
    "db:push": "pnpm --filter=db exec prisma db push",
    "db:seed": "pnpm --filter=db exec prisma db seed",
    "db:studio": "pnpm --filter=db exec prisma studio",
    "db:migrate": "pnpm --filter=db exec prisma migrate dev",
    "clean": "pnpm -r --parallel exec rm -rf node_modules .turbo dist",
    "help": "echo 'Available commands: dev, build, test, lint, db:push, db:seed'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}