{
  "name": "able-ai-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ABLE AI-powered creator economy platform",
  "license": "PROPRIETARY",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @able/db prisma generate",
    "db:migrate": "pnpm --filter @able/db prisma migrate dev",
    "db:push": "pnpm --filter @able/db prisma db push",
    "db:studio": "pnpm --filter @able/db prisma studio",
    "db:seed": "pnpm --filter @able/db prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.20.0",
    "eslint": "^9.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0"
  }
}
