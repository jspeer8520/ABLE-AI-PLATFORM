generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations UserOrganization[]
  products      Product[]
  orders        Order[]
  subscriptions Subscription[]
  contacts      Contact[]
  emails        Email[]
  workflows     Workflow[]
  usageLogs     UsageLog[]
  creditBalance CreditBalance?

  @@index([email])
  @@index([createdAt])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  createdAt DateTime @default(now())

  users         UserOrganization[]
  products      Product[]
  orders        Order[]
  subscriptions Subscription[]
  contacts      Contact[]
  emails        Email[]
  workflows     Workflow[]
  usageLogs     UsageLog[]

  @@index([createdAt])
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Plan {
  id             String   @id @default(cuid())
  name           String
  price          Int
  stripePriceId  String?
  maxProducts    Int      @default(10)
  maxEmails      Int      @default(1000)
  maxWorkflows   Int      @default(5)
  monthlyCredits Int      @default(1000)
  createdAt      DateTime @default(now())

  subscriptions Subscription[]

  @@unique([name])
}

model Subscription {
  id                   String    @id @default(cuid())
  organizationId       String
  userId               String
  planId               String
  stripeSubscriptionId String?
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([status])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  slug           String
  description    String?
  price          Int
  type           String
  image          String?
  stripePriceId  String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([published])
}

model Order {
  id              String   @id @default(cuid())
  organizationId  String
  productId       String
  customerId      String
  userId          String
  amount          Int
  status          String   @default("completed")
  stripeSessionId String?
  customerEmail   String
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer     Contact      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  name           String?
  status         String   @default("lead")
  ltv            Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]
  user         User?        @relation(fields: [userId], references: [id])
  userId       String?

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
}

model Email {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  subject        String
  htmlBody       String
  variables      String   @default("[]")
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns    EmailCampaign[]

  @@index([organizationId])
}

model EmailCampaign {
  id             String    @id @default(cuid())
  emailId        String
  organizationId String
  sentCount      Int       @default(0)
  status         String    @default("draft")
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([organizationId])
}

model Workflow {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  trigger        String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions      WorkflowAction[]

  @@index([organizationId])
  @@index([trigger])
}

model WorkflowAction {
  id         String   @id @default(cuid())
  workflowId String
  type       String
  config     String
  position   Int
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model UsageLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  feature        String
  costInCredits  Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([feature])
  @@index([createdAt])
}

model CreditBalance {
  id                String   @id @default(cuid())
  userId            String   @unique
  balance           Int      @default(1000)
  monthlyAllocation Int      @default(1000)
  resetAt           DateTime
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resetAt])
}
