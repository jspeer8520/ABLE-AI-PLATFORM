{
  "compilerOptions": {

    "target": "ES2022",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",

    "moduleResolution": "node",

    "strict": true,

    "noUncheckedIndexedAccess": true,

    "noImplicitOverride": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "allowJs": false,

    "isolatedModules": true,

    "esModuleInterop": true
  }
}
